DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/ems_dev?schema=public"
JWT_SECRET="replace-with-strong-secret"
JWT_EXPIRES_IN="15m"

# Port the API listens on (frontend NEXT_PUBLIC_API_URL must match this host:port)
PORT=8000

# Optional: comma-separated origins for CORS (leave unset in dev to allow all)
# CORS_ORIGIN=http://localhost:3000
